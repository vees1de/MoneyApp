# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=moneyapp-backend
APP_ENV=development

# ── HTTP ─────────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
BACKEND_PORT=8080

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=moneyapp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_DSN=postgres://postgres:postgres@postgres:5432/moneyapp?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_ADDR=redis:6379

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_PORT=9094
KAFKA_UI_PORT=8090
KAFKA_BROKERS=kafka:9092

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_ISSUER=moneyapp
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
AUTH_ALLOW_INSECURE_DEV_AUTH=true

# ── Integrations ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URL=
