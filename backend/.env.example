APP_NAME=moneyapp-backend
APP_ENV=development

HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

DATABASE_DSN=postgres://postgres:postgres@localhost:5432/moneyapp?sslmode=disable
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=30m

AUTH_JWT_SECRET=change-me
AUTH_JWT_ISSUER=moneyapp
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
AUTH_ALLOW_INSECURE_DEV_AUTH=true

DEFAULT_BASE_CURRENCY=RUB
DEFAULT_TIMEZONE=Europe/Amsterdam
DEFAULT_WEEKLY_REVIEW_HOUR=18

TELEGRAM_BOT_TOKEN=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URL=
