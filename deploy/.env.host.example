APP_DOMAIN=moneyapp.example.com www.moneyapp.example.com
SSL_PRIMARY_DOMAIN=moneyapp.example.com
APP_PORT=8080

APP_USER=moneyapp
APP_GROUP=moneyapp
SYSTEMD_SERVICE_NAME=moneyapp
NGINX_SITE_NAME=moneyapp.conf

TARGET_GOOS=linux
TARGET_GOARCH=amd64

INSTALL_NGINX=true
BOOTSTRAP_POSTGRES=true

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=moneyapp
POSTGRES_USER=moneyapp
POSTGRES_PASSWORD=change-me
DATABASE_DSN=

APP_NAME=moneyapp-backend
APP_ENV=production
HTTP_ADDR=127.0.0.1:8080
AUTH_JWT_SECRET=change-me
AUTH_JWT_ISSUER=moneyapp
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
AUTH_ALLOW_INSECURE_DEV_AUTH=false

REDIS_ENABLED=false
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DASHBOARD_TTL=30s

KAFKA_ENABLED=false
KAFKA_CLIENT_ID=moneyapp-backend
KAFKA_AUDIT_TOPIC=moneyapp.audit
KAFKA_WRITE_TIMEOUT=5s

DEFAULT_BASE_CURRENCY=RUB
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_WEEKLY_REVIEW_HOUR=18

TELEGRAM_BOT_TOKEN=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URL=
