APP_DOMAIN=moneyapp.example.com
APP_PORT=8080

APP_NAME=moneyapp-backend
APP_ENV=production

POSTGRES_DB=moneyapp
POSTGRES_USER=moneyapp
POSTGRES_PASSWORD=change-me

REDIS_ENABLED=true
